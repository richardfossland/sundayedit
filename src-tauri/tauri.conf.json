{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Verbatim",
  "version": "0.1.0",
  "identifier": "app.verbatim",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Verbatim",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "shortDescription": "AI-assisted video captioning",
    "longDescription": "Verbatim turns raw video into broadcast-ready captions fast: local speech recognition with per-word confidence, context priming, AI polish, translation, speaker labels, styling, and burn-in export.",
    "copyright": "© 2026 Richard Fossland",
    "publisher": "Richard Fossland",
    "homepage": "https://verbatim.app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ0QkU4N0Q0OUY3RkI3NjIKUldSaXQzK2YxSWUrUk1FYzVpbTRVSzZZUjhVRHlGOHRmY0FqL3NxSEdoakxPTFVGamNPUEo4TEYK",
      "endpoints": [
        "https://github.com/richardfossland/verbatim/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
